{
  "version": "1",
  "operation": "image.edit",
  "model": "REPLACE_WITH_LIVE_INPAINT_MODEL_ID",
  "prompt": "Change the sky to a warm sunset while preserving the person, clothing, camera angle, and foreground geometry.",
  "parameters": {
    "aspect_ratio": "auto",
    "output_format": "png"
  },
  "inputs": {
    "image": "/absolute/path/to/source.png"
  },
  "output": {
    "directory": "./venice-media-output",
    "filename": "edited.png",
    "write_metadata": true
  },
  "execution": {
    "dry_run": true
  },
  "attestations": {
    "seedance_face_consent": false
  }
}
